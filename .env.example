# Copy this file to .env and fill in your values.
# The .env file is read automatically by pydantic-settings at startup.

# ── Required ───────────────────────────────────────────────────────────────
# Your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# ── Optional overrides ─────────────────────────────────────────────────────
# These values can also be set in config/settings.yaml.

# Database URL (default: SQLite at ./data/app.db)
# DATABASE__URL=sqlite:///./data/app.db

# Enable FastAPI debug mode (auto-reload, verbose errors)
# DEBUG=false

# Audio storage directory
# AUDIO__STORAGE_DIR=./data/audio

# VAD aggressiveness (0–3); higher = more aggressive noise filtering
# AUDIO__VAD_AGGRESSIVENESS=2

# Transcription model (must be a Whisper-compatible model on OpenRouter)
# OPENROUTER__TRANSCRIPTION__MODEL=openai/whisper-1

# Summarization model
# OPENROUTER__SUMMARIZATION__MODEL=anthropic/claude-3.5-sonnet
